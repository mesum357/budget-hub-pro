# Backend origin for the browser (Vite injects only vars prefixed with VITE_).
# Local: leave empty or omit — `/api` and `/uploads` are proxied to the API in vite.config.ts.
# Render / production: set to your deployed API, no trailing slash.
# Example: VITE_API_URL=https://budget-management-backend.onrender.com
VITE_API_URL=
