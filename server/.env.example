# Copy this file to `server/.env` and fill in values.
# The Node API loads ONLY this file — not `.env` in the repo root.

MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/budget-hub-pro?retryWrites=true&w=majority&appName=budget-hub-pro

SESSION_SECRET=replace-with-long-random-string
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=admin123
PORT=5000
# Optional: comma-separated. If unset, any localhost / 127.0.0.1 origin is allowed.
# CORS_ORIGIN=http://localhost:8080
